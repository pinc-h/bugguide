#!/usr/bin/env ruby
require 'commander/import'
require 'bugguide'

program :name, 'BugGuide'
program :version, BugGuide::VERSION
program :description, 'Command-line tool for scraping data from https://bugguide.net'

command :checklist do |c|
  c.syntax = "bugguide checklist [taxon name]"
  c.option "-s", '--state STATE', String, '2-letter code of a US state or CA province'
  c.option "-f", '--format table|csv', String, "Output format"
  c.action do |args, opts|
    if args.empty?
      abort "You must specify a taxon name"
    end
    
    puts "# BugGuide Checklist Generator"
    puts "# Generated on #{Time.now.strftime("%Y-%m-%d %H:%M:%S")}"
    puts "# Searching for #{args[0]} in #{opts.state || 'all locations'}..."
    puts ""
    
    # Get all matching taxa directly
    taxa = BugGuide::Taxon.search(args[0], state: opts.state)
    
    if taxa.empty?
      abort "No matching taxa found"
    end
    
    # Output the checklist
    if opts.format == 'csv'
      puts "TAXON ID,NAME"
      taxa.each do |t|
        puts "#{t.id},#{t.scientific_name}"
      end
    else
      # Find the longest name for formatting
      longest_name = taxa.map { |t| t.scientific_name.to_s.length }.max || 20
      
      puts "Found #{taxa.size} taxa:"
      puts ""
      puts "TAXON ID".ljust(10) + "NAME"
      puts "-" * (10 + longest_name + 5)
      
      taxa.each do |t|
        puts t.id.to_s.ljust(10) + t.scientific_name.to_s
      end
    end
  end
end
